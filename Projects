<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Projects | AI in Construction Portfolio</title>

  <style>
    :root {
      --cream: #f5ead8;
      --light-cream: #fff8ec;
      --dark: #1f1d1a;
      --dark-soft: #2d2924;
      --gold: #c8a45d;
      --gold-dark: #8d6f35;
      --muted: #6d6458;
      --line: #d6c4a3;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Georgia, "Times New Roman", serif;
      background-color: var(--cream);
      color: var(--dark);
      line-height: 1.6;
    }

    .page {
      width: min(1100px, 100%);
      margin: 0 auto;
      background-color: var(--light-cream);
      min-height: 100vh;
      border-left: 8px solid var(--gold);
      border-right: 8px solid var(--gold);
    }

    header {
      background-color: var(--dark);
      color: var(--light-cream);
      padding: 18px 7%;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-weight: bold;
      font-size: 1.1rem;
      letter-spacing: 1px;
    }

    nav a {
      color: var(--light-cream);
      text-decoration: none;
      margin-left: 24px;
      font-family: Arial, sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    nav a:hover {
      color: var(--gold);
    }

    .page-header {
      padding: 80px 8% 55px;
      background:
        radial-gradient(circle at top left, rgba(200,164,93,0.22), transparent 30%),
        var(--light-cream);
      border-bottom: 1px solid var(--line);
    }

    .eyebrow {
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.8rem;
      color: var(--gold-dark);
      font-weight: bold;
      margin-bottom: 18px;
    }

    h1 {
      font-size: clamp(2.6rem, 6vw, 4.8rem);
      line-height: 1;
      letter-spacing: -2px;
      margin-bottom: 22px;
    }

    .page-header p {
      color: var(--muted);
      max-width: 780px;
      font-size: 1.05rem;
    }

    .projects-section {
      background-color: var(--dark);
      color: var(--light-cream);
      padding: 70px 8%;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .project-card {
      background-color: var(--dark-soft);
      border: 1px solid rgba(255, 248, 236, 0.25);
      padding: 22px;
      min-height: 330px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .project-card:hover {
      border-color: var(--gold);
    }

    .project-image {
      height: 135px;
      border: 1px solid rgba(255, 248, 236, 0.25);
      background:
        linear-gradient(135deg, rgba(200, 164, 93, 0.25), rgba(255,255,255,0.05)),
        repeating-linear-gradient(45deg, rgba(255,255,255,0.06), rgba(255,255,255,0.06) 8px, transparent 8px, transparent 16px);
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-size: 0.75rem;
      color: rgba(255, 248, 236, 0.65);
    }

    .tag {
      font-family: Arial, sans-serif;
      color: var(--gold);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 8px;
    }

    .project-card h2 {
      font-size: 1.35rem;
      line-height: 1.15;
      margin-bottom: 12px;
    }

    .project-card p {
      font-family: Arial, sans-serif;
      color: rgba(255, 248, 236, 0.74);
      font-size: 0.9rem;
      margin-bottom: 18px;
    }

    .project-card a {
      color: var(--gold);
      text-decoration: none;
      font-family: Arial, sans-serif;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.78rem;
    }

    footer {
      background-color: var(--dark);
      color: var(--light-cream);
      padding: 30px 8%;
      font-family: Arial, sans-serif;
      font-size: 0.85rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      border-top: 1px solid rgba(200, 164, 93, 0.35);
    }

    footer a {
      color: var(--gold);
      text-decoration: none;
    }

    @media (max-width: 900px) {
      .project-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 650px) {
      header {
        flex-direction: column;
        align-items: flex-start;
        gap: 14px;
      }

      nav a {
        margin-left: 0;
        margin-right: 16px;
      }

      .project-grid {
        grid-template-columns: 1fr;
      }

      .page {
        border-left: none;
        border-right: none;
      }
    }
  </style>
</head>

